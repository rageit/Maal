<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0f1117" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="description" content="Track points for your Marriage card game sessions" />
    <title>@ViewData["Title"] - Maal</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.png" />
    <link rel="manifest" href="~/manifest.json" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Google AdSense: Replace ca-pub-XXXXXXXXXXXXXXXX with your real publisher ID -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX"
            crossorigin="anonymous"></script>
</head>
<body class="@ViewData["BodyClass"]">
    <header class="app-header">
        <a class="app-logo" asp-page="/Index"><span class="app-logo-icon">&#9824;</span> MAAL</a>
        <nav class="app-nav">
            <a asp-page="/Index">Home</a>
            <a asp-page="/Games">History</a>
            <a asp-page="/NewGame" class="app-nav-new">New Game</a>
        </nav>
    </header>

    <div class="ad-banner ad-banner-top">
        <!-- Top banner ad: Replace data-ad-slot with your real ad unit ID -->
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
             data-ad-slot="XXXXXXXXXX"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <div class="app-content">
        @RenderBody()
    </div>

    <div class="ad-banner ad-banner-bottom">
        <!-- Bottom banner ad: Replace data-ad-slot with your real ad unit ID -->
        <ins class="adsbygoogle"
             style="display:block"
             data-ad-client="ca-pub-XXXXXXXXXXXXXXXX"
             data-ad-slot="XXXXXXXXXX"
             data-ad-format="auto"
             data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
