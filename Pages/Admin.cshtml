@page
@model AdminModel
@{
    ViewData["Title"] = "Admin";
}

<h1 class="card-title" style="font-size:1.4rem; margin-bottom:4px;">Admin</h1>
<p class="text-muted mb-2" style="font-size:0.9rem;">All games across all users</p>

@if (Model.UserGroups.Any())
{
    <div class="text-muted mb-2" style="font-size:0.85rem;">
        @Model.UserGroups.Count user@(Model.UserGroups.Count != 1 ? "s" : "") &middot;
        @Model.UserGroups.Sum(g => g.Games.Count) total game@(Model.UserGroups.Sum(g => g.Games.Count) != 1 ? "s" : "")
    </div>

    @foreach (var group in Model.UserGroups)
    {
        <div class="card">
            <div class="d-flex align-center justify-between mb-1">
                <div class="card-title" style="margin:0; font-size:0.95rem;">
                    User: @group.UserId.Substring(0, Math.Min(8, group.UserId.Length))&hellip;
                </div>
                <span class="badge badge-maal">@group.Games.Count game@(group.Games.Count != 1 ? "s" : "")</span>
            </div>

            @foreach (var item in group.Games)
            {
                <a asp-page="/Scoreboard" asp-route-gameId="@item.Game.Id" asp-route-admin="true" class="game-item" style="margin-bottom:8px;">
                    <div class="game-item-info">
                        <div class="game-name">@item.Game.Name</div>
                        <div class="game-meta">
                            @item.Game.TimeStamp.ToString("MMM dd, yyyy") &middot;
                            @item.RoundCount round@(item.RoundCount != 1 ? "s" : "") &middot;
                            @string.Join(", ", item.PlayerNames)
                        </div>
                    </div>
                    <div class="game-item-arrow">&#8250;</div>
                </a>
            }
        </div>
    }
}
else
{
    <div class="empty-state">
        <div class="empty-state-icon">&#9881;</div>
        <div class="empty-state-title">No games yet</div>
        <p class="empty-state-text">No users have created any games</p>
    </div>
}
